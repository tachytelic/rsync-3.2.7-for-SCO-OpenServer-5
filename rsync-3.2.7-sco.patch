diff -ruN rsync_clean/main.c rsync_patched/main.c
--- rsync_clean/main.c	2022-10-02 16:54:59.000000000 +0000
+++ rsync_patched/main.c	2026-05-03 00:21:32.240875578 +0000
@@ -171,6 +171,7 @@
 {
 	char *shell = getenv("RSYNC_SHELL");
