diff -ruN rsync_clean/options.c rsync_patched/options.c
--- rsync_clean/options.c	2022-09-10 20:14:42.000000000 +0000
+++ rsync_patched/options.c	2026-05-03 00:21:32.232875673 +0000
@@ -1288,6 +1288,8 @@
 static void create_refuse_error(int which)
 {
 	const char *msg;
+	struct poptOption *op;
+	int n;
 	if (am_daemon)
 		msg = "The server is configured to refuse";
 	else if (am_server)
@@ -1296,8 +1298,8 @@
 		msg = "This rsync does not support";
 
 	/* The "which" value is the index + OPT_REFUSED_BASE. */
-	struct poptOption *op = &long_options[which - OPT_REFUSED_BASE];
